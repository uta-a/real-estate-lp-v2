---
import SectionHeading from "../ui/SectionHeading.astro";

const info = [
  { label: "会社名", value: "株式会社XX不動産" },
  { label: "代表者", value: "山田 太郎" },
  { label: "所在地", value: "佐賀県佐賀市〇〇町1-2-3" },
  { label: "電話番号", value: "0120-XXX-XXX" },
  { label: "営業時間", value: "9:00〜18:00（土日祝も対応）" },
  { label: "免許番号", value: "佐賀県知事(X)第XXXXX号" },
];
---

<section id="company" class="bg-white py-16 md:py-24">
  <div class="max-w-[1200px] mx-auto px-5 md:px-8">
    <div class="fade-in">
      <SectionHeading tag="Company">
        会社紹介
      </SectionHeading>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">
      {/* 画像 */}
      <div class="fade-in">
        <img
          src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80"
          alt="XX不動産オフィス外観"
          class="w-full rounded-xl shadow-md aspect-[4/3] object-cover"
          loading="lazy"
        />
      </div>

      {/* 情報 */}
      <div class="fade-in">
        <dl class="divide-y divide-border">
          {info.map(({ label, value }) => (
            <div class="flex flex-col sm:flex-row gap-1 sm:gap-4 py-4">
              <dt class="text-text-light font-bold text-base sm:w-32 shrink-0">{label}</dt>
              <dd class="text-text text-base">{value}</dd>
            </div>
          ))}
        </dl>

        {/* 代表メッセージ */}
        <blockquote class="mt-8 pl-5 border-l-4 border-accent">
          <p class="text-base text-text leading-relaxed italic">
            「佐賀で生まれ育った私たちだからこそ、地域の皆さまのお気持ちに寄り添った対応を心がけています。空き家や実家の売却でお困りのことがあれば、どんな些細なことでもお気軽にご相談ください。」
          </p>
          <footer class="mt-3 text-sm text-text-light">
            代表取締役 山田 太郎
          </footer>
        </blockquote>
      </div>
    </div>
  </div>
</section>
