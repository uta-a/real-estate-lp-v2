---
const phone = "0120-XXX-XXX";
const phoneHref = `tel:${phone.replace(/-/g, "")}`;
---

<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white border-t border-border shadow-[0_-2px_10px_rgba(0,0,0,0.1)]">
  <div class="flex">
    <a
      href={phoneHref}
      class="flex-1 flex items-center justify-center gap-2 py-3.5 bg-primary text-white font-bold text-base min-h-[56px]"
      aria-label="電話で問い合わせ"
    >
      <span class="material-symbols-outlined text-xl" aria-hidden="true">call</span>
      電話する
    </a>
    <a
      href="#contact"
      class="flex-1 flex items-center justify-center gap-2 py-3.5 bg-accent text-primary-dark font-bold text-base min-h-[56px]"
    >
      <span class="material-symbols-outlined text-xl" aria-hidden="true">description</span>
      無料査定
    </a>
  </div>
</div>
