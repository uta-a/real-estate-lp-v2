---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="flex items-start gap-3 py-3">
  <span class="material-symbols-outlined text-xl text-accent shrink-0 mt-0.5" aria-hidden="true">
    check_circle
  </span>
  <p class="text-base md:text-lg text-text leading-relaxed">{text}</p>
</div>
