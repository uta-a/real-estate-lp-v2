---
interface Props {
  step: number;
  icon: string;
  title: string;
}

const { step, icon, title } = Astro.props;
---

<div class="flex flex-col items-center text-center">
  <div class="relative mb-4">
    <div class="w-16 h-16 rounded-full bg-primary flex items-center justify-center">
      <span class="material-symbols-outlined text-3xl text-white" aria-hidden="true">{icon}</span>
    </div>
    <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-accent text-primary-dark text-sm font-bold flex items-center justify-center">
      {step}
    </span>
  </div>
  <h3 class="text-lg md:text-xl font-bold text-primary mb-2">{title}</h3>
  <p class="text-base text-text-light leading-relaxed">
    <slot />
  </p>
</div>
