---
interface Props {
  icon?: string;
  title: string;
  class?: string;
}

const { icon, title, class: className } = Astro.props;
---

<div class:list={["bg-white rounded-xl p-6 md:p-8 shadow-sm border border-border", className]}>
  {icon && (
    <div class="w-14 h-14 rounded-full bg-accent/10 flex items-center justify-center mb-5">
      <span class="material-symbols-outlined text-3xl text-accent" aria-hidden="true">
        {icon}
      </span>
    </div>
  )}
  <h3 class="text-xl md:text-2xl font-bold text-primary mb-3">{title}</h3>
  <p class="text-base text-text-light leading-relaxed">
    <slot />
  </p>
</div>
