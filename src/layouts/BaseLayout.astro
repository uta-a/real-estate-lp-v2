---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "佐賀の実家・空き家買取｜XX不動産",
  description = "佐賀県の実家・空き家の不動産買取なら XX不動産。仲介手数料0円、最短1週間で現金化。そのままの状態でお売りいただけます。まずは無料査定からお気軽にご相談ください。",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=BIZ+UDPGothic:wght@400;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">メインコンテンツへ</a>
    <slot />
    <script src="../scripts/scroll-animation.js"></script>
    <script src="../scripts/accordion.js"></script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
